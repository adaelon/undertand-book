# Fluid LLM config ‚Äî copy to `.env` and fill in. `.env` is gitignored (holds the key).
# Loaded at startup by the backend (crates/fluid-server/src/main.rs). Real
# environment variables override these.

# Required: API key for the OpenAI-compatible LLM gateway. Without it,
# /api/generate returns 503 on a cache miss.
OPENCODE_API_KEY=sk-your-key-here

# Optional: OpenAI-compatible base URL (default below = opencode "zen" gateway).
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Optional: model id (default glm-5.1). Must exist on the gateway (GET /models).
# The model id also feeds the cache key, so switching it invalidates cached capsules.
FLUID_LLM_MODEL=glm-5.1
